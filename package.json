{
	"private": true,
	"type": "module",
	"scripts": {
		"build": "pnpm -r build",
		"build:foundry-marketplace": "node ./scripts/build-foundry-marketplace-body.mjs --module forge",
		"dev:v13": "node ./scripts/run-foundry-dev.mjs --target v13-dev --module rpgm-forge",
		"dev:v14": "node ./scripts/run-foundry-dev.mjs --target v14-dev --module rpgm-forge",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"publish:foundry": "node ./scripts/publish-foundry-package.mjs",
		"publish:foundry:marketplace": "node ./scripts/update-foundry-marketplace-page.mjs --module forge --edit-url https://foundryvtt.com/packages/rpgm-forge/edit",
		"publish:foundry:marketplace:dry-run": "node ./scripts/update-foundry-marketplace-page.mjs --module forge --edit-url https://foundryvtt.com/packages/rpgm-forge/edit --dry-run",
		"publish:foundry:dry-run": "node ./scripts/publish-foundry-package.mjs --dry-run",
		"release:forge:prepare": "pnpm build && pnpm build:foundry-marketplace",
		"setup:playwright": "playwright install chromium",
		"test:v13": "pnpm dev:v13",
		"test:v14": "pnpm dev:v14"
	},
	"devDependencies": {
		"@types/node": "^22.13.10",
		"@typescript-eslint/eslint-plugin": "^8.58.0",
		"@vitejs/plugin-vue": "^5.2.1",
		"eslint": "^9.25.1",
		"eslint-plugin-jsdoc": "^50.8.0",
		"eslint-plugin-simple-import-sort": "^12.1.1",
		"eslint-plugin-vue": "^10.8.0",
		"fvtt-types": "github:League-of-Foundry-Developers/foundry-vtt-types#main",
		"naive-ui": "^2.44.1",
		"oxlint": "^0.16.7",
		"playwright": "^1.59.1",
		"pnpm": "^10.18.3",
		"typescript-eslint": "^8.58.0",
		"typescript-vue-plugin": "^1.8.27",
		"unplugin-auto-import": "19.1.2",
		"unplugin-macros": "^0.19.1",
		"vite": "^6.2.1",
		"vue-tsc": "^2.2.10"
	},
	"dependencies": {
		"@ai-sdk/openai-compatible": "^1.0.13",
		"@ai-sdk/provider": "^2.0.0",
		"@eslint/js": "^9.33.0",
		"@floating-ui/vue": "^1.1.11",
		"@polar-sh/better-auth": "^1.0.8",
		"@polar-sh/sdk": "^0.34.13",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@types/showdown": "^2.0.6",
		"@vueuse/core": "^13.1.0",
		"@xsolla/login-sdk": "^0.111.6",
		"ai": "^5.0.27",
		"better-auth": "^1.3.4",
		"brigadier-ts-lite": "^1.0.1",
		"csstype": "^3.2.3",
		"iso-639-1": "^3.1.5",
		"neverthrow": "^8.2.0",
		"showdown": "^2.1.0",
		"slugify": "^1.6.6",
		"vue": "^3.5.32",
		"vue-router": "^4.5.1",
		"zod": "^4.3.6"
	}
}
